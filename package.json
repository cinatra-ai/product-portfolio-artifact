{
  "name": "@cinatra-ai/product-portfolio-artifact",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "src",
    "skills"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "peerDependencies": {
    "@cinatra-ai/sdk-extensions": "*"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    }
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "artifact",
    "dependencies": [],
    "artifact": {
      "accepts": {
        "file": {
          "mimeTypes": [
            "text/markdown",
            "text/plain",
            "application/pdf"
          ]
        }
      },
      "skills": {
        "matchers": [
          "@cinatra-ai/product-portfolio-artifact:product-portfolio-matcher"
        ]
      },
      "matcherConfidenceThreshold": 0.7
    },
    "consumes": []
  }
}
